{
  "name": "napasvpn",
  "version": "2.0.0",
  "description": "NapasVPN — VLESS+Reality client for Windows",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "concurrently \"BROWSER=none react-scripts start\" \"wait-on http://localhost:3000 && electron .\"",
    "react-start": "react-scripts start",
    "electron-start": "electron .",
    "build": "react-scripts build && electron-builder",
    "build:win": "react-scripts build && electron-builder --win --x64"
  },
  "dependencies": {
    "framer-motion": "^10.16.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "react-scripts": "5.0.1",
    "wait-on": "^7.2.0"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.napasvpn.app",
    "productName": "NapasVPN",
    "copyright": "Copyright © 2024 NapasVPN",
    "extraMetadata": {
      "main": "main.js"
    },
    "asar": false,
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NapasVPN",
      "deleteAppDataOnUninstall": false,
      "include": "assets/installer.nsh"
    },
    "files": [
      "build/**/*",
      "main.js",
      "preload.js",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "publish": null
  }
}
